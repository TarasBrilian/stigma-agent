# Public config only — NEVER put secrets (private keys, API secrets) in the
# frontend. Only NEXT_PUBLIC_* values are exposed to the browser.

# Backend REST API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Casper network
NEXT_PUBLIC_CASPER_NETWORK=casper-test

# Browser → Casper node RPC endpoint (submit user-signed deploys + read entity
# state). LOCAL DEV: "/casper-rpc" uses the same-origin Next.js rewrite (below) to
# reach the node, dodging its missing CORS headers. PRODUCTION (e.g. Vercel):
# point this at the BACKEND's relay instead — an edge rewrite can choke on the
# ~1 MB Vault deploy body — e.g. https://<backend-host>/casper-rpc (the backend
# has open CORS and a raised body limit).
NEXT_PUBLIC_CASPER_NODE_URL=/casper-rpc
# Upstream the LOCAL Next.js /casper-rpc rewrite forwards to (dev only).
CASPER_RPC_UPSTREAM=https://node.testnet.casper.network/rpc

# Contract hashes the UI passes to `Vault::init` when the USER signs the
# create-vault deploy (see ADR 0001 — the user deploys Vault.wasm, so the client
# supplies agent/oracle/router/assets[5]). Values below are PUBLIC testnet package
# hashes from ../contract/deployed.casper-test.json. There is NO registry hash
# here: the backend (not the UI) calls VaultRegistry.register; all reads go via
# the backend.

# The shared agent public key (the `agent` init arg). NOT a secret — it is only
# the public key; the agent SECRET key lives in the backend. Source it from the
# backend's AGENT_PUBLIC_KEY / the deploy operator.
NEXT_PUBLIC_AGENT_PUBLIC_KEY=

NEXT_PUBLIC_ORACLE_HASH=hash-b7a88105f1895aade1eddff75da751ddb31e7c53ddd5876fb1946b48337a6369
NEXT_PUBLIC_ROUTER_HASH=hash-8a415764e5062ad3f228b013f986dd529cb1f311858f2b84756c1946432e5cf3

# Per-asset token package hashes (canonical order); mUSDC also backs the deposit approve.
NEXT_PUBLIC_TOKEN_MUSDC_HASH=hash-4847bc198c6641daf3c8ac40211a8180800d630fb756ab7911ffc0eb81310a9b
NEXT_PUBLIC_TOKEN_MBTC_HASH=hash-f8f4931076a8766061319e9c277151b8aa5f9c96c50bf5304443a4cc8ff52370
NEXT_PUBLIC_TOKEN_MNVDAX_HASH=hash-9a3d90b3ce61ae24533ba84b6a800faeb7199787f2cf77f476cb870b0aaadf1a
NEXT_PUBLIC_TOKEN_MXAUT_HASH=hash-52596790c10528740a44d028eab13360ea12cc4ff953521e0a7802fdfab2accf
NEXT_PUBLIC_TOKEN_MGOOGLX_HASH=hash-84e72cd3ba99d5dab36fc1dd80e64a5c1e581e1a5296b4378fe1a6d1948779a5
