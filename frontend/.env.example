# Public config only — NEVER put secrets (private keys, API secrets) in the
# frontend. Only NEXT_PUBLIC_* values are exposed to the browser.

# Backend REST API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Casper network
NEXT_PUBLIC_CASPER_NETWORK=casper-test

# Public node RPC, used ONLY to submit user-signed deploys.
# Portfolio reads go through the backend, not directly from the browser.
NEXT_PUBLIC_CASPER_NODE_URL=

# Contract hash(es) the UI needs for display (from ../contract deploy output).
NEXT_PUBLIC_VAULT_FACTORY_HASH=
