# Stigma Agent — backend env template. Copy to .env and fill in.
# `secrets/` and `.env` are gitignored — never commit real keys.

# --- database ---
DATABASE_URL="postgresql://user:pass@localhost:5432/stigma?schema=public"

# --- Casper (testnet) ---
# Public package hashes come from ../contract/deployed.casper-test.json.
CASPER_NODE_URL="https://node.testnet.casper.network/rpc"
CASPER_NETWORK_NAME="casper-test"
CSPR_CLOUD_API_KEY=""                 # CSPR.cloud (event streaming / reads), optional

# deployed shared infrastructure (NOTE: registry, not a factory)
VAULT_REGISTRY_HASH="hash-..."
ORACLE_HASH="hash-..."
ROUTER_HASH="hash-..."

# CEP-18 token package hashes (canonical asset order: mUSDC, mBTC, mNVDAx, mXAUT, mGOOGLx)
TOKEN_MUSDC_HASH="hash-..."
TOKEN_MBTC_HASH="hash-..."
TOKEN_MNVDAX_HASH="hash-..."
TOKEN_MXAUT_HASH="hash-..."
TOKEN_MGOOGLX_HASH="hash-..."

# agent hot key — secret. Only execute_buy / rebalance / setPrice / faucet writes need it.
AGENT_SECRET_KEY_PATH="./secrets/agent_secret_key.pem"
# AGENT_PUBLIC_KEY="01..."            # optional convenience for the agent account

# --- LLM (agent module) ---
# Optional: without a key, profiling falls back to a deterministic heuristic.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-oss-120b:free"

# --- prices & billing ---
PRICE_API_KEY=""                      # stock source key (NVDA/GOOGL); Twelve Data by default
# COINGECKO_API_KEY=""                 # optional CoinGecko demo key (BTC/gold work keyless)
# COINGECKO_URL=""                     # override CoinGecko base (default api.coingecko.com/api/v3)
# STOCK_API_URL=""                     # override stock base (default api.twelvedata.com)
X402_FACILITATOR_URL=""               # x402 micro-fee (not yet wired)

# --- server ---
PORT=3001
FRONTEND_ORIGIN="http://localhost:3000"
